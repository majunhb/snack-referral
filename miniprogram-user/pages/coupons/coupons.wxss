.tabs { display: flex; background: #fff; border-radius: 20rpx; padding: 16rpx; margin-bottom: 24rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: #666; border-radius: 12rpx; }
.tab.active { background: linear-gradient(135deg, #FF6B35, #F7931E); color: #fff; font-weight: 600; }

.coupon {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.coupon.used { opacity: 0.5; filter: grayscale(60%); }
.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #FF6B35, #F7931E);
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}
.coupon-value { font-size: 56rpx; font-weight: 700; }
.coupon-condition { font-size: 24rpx; margin-top: 8rpx; }

.coupon-right { flex: 1; padding: 24rpx; }
.coupon-title { font-size: 30rpx; font-weight: 600; color: #333; }
.coupon-source, .coupon-expire { color: #999; font-size: 24rpx; margin-top: 8rpx; }
.coupon-status { display: inline-block; margin-top: 12rpx; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 100rpx; }
.status-0 { background: #FFE4D6; color: #FF6B35; }
.status-1 { background: #f0f0f0; color: #999; }
.status-2 { background: #fde2e2; color: #d33; }

.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
