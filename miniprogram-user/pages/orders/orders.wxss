.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }

.order { padding: 24rpx; }
.status-text { font-size: 26rpx; padding: 4rpx 16rpx; border-radius: 100rpx; }
