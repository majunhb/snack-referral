.invite-hero { text-align: center; padding: 40rpx 0; }
.hero-title { font-size: 44rpx; font-weight: 700; color: #FF6B35; }
.hero-sub { color: #666; font-size: 28rpx; margin-top: 16rpx; }

.qr-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.qr-wrapper {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 16rpx;
}
.qr-img { width: 100%; height: 100%; }
.qr-tip { color: #999; font-size: 24rpx; margin-top: 16rpx; }

.stats-card, .rules { margin-top: 24rpx; }
.stat-row { display: flex; margin-top: 24rpx; }
.stat-row .col { flex: 1; text-align: center; }
.stat-num { font-size: 56rpx; font-weight: 700; }
.stat-label { color: #999; font-size: 26rpx; }
.rule-item { color: #666; font-size: 28rpx; line-height: 1.9; margin-top: 8rpx; }

.share-btn {
  margin-top: 40rpx;
  background: #FFE4D6;
  color: #FF6B35;
  border-radius: 100rpx;
  font-size: 30rpx;
}
