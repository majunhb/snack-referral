/** 全局样式 - 橘色温暖主题 */
page {
  background: #FFF5E6;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, "Microsoft YaHei", Arial, sans-serif;
  color: #333;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%);
  color: #fff;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.btn-secondary {
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 100rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
}

.text-orange { color: #FF6B35; }
.text-mute { color: #999; font-size: 24rpx; }

.title-xl { font-size: 48rpx; font-weight: 700; color: #333; }
.title-lg { font-size: 36rpx; font-weight: 600; color: #333; }
.title-md { font-size: 30rpx; font-weight: 500; }

.row { display: flex; align-items: center; }
.col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.center { display: flex; justify-content: center; align-items: center; }

.mt-8  { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
