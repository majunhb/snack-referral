# 服务端口
PORT=3000
NODE_ENV=development

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=snack_referral
DB_USER=root
DB_PASSWORD=root123

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=please_change_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# 微信支付 V3
WX_APPID=wxdc45c83956b489e9
WX_MCHID=YOUR_MERCHANT_ID
WX_PAY_V3_KEY=YOUR_32CHARS_API_V3_KEY
WX_NOTIFY_URL=https://yourdomain.com/api/order/pay-callback
# 微信消息加密解密私钥路径（相对于 server/ 目录）
WX_ENCODING_AES_KEY_PATH=./keys/wechat/private.wxdc45c83956b489e9.key
WX_ENCODING_TOKEN=YOUR_ENCODING_TOKEN

# 支付宝
ALI_APPID=2021000000000000
ALI_PRIVATE_KEY_PATH=./keys/ali_app_private_key.pem
ALI_PUBLIC_KEY_PATH=./keys/ali_public_key.pem
ALI_NOTIFY_URL=https://yourdomain.com/api/order/pay-callback

# 短信
SMS_ACCESS_KEY=your_sms_key
SMS_ACCESS_SECRET=your_sms_secret
SMS_SIGN_NAME=小吃店
SMS_TEMPLATE_CODE=SMS_000000001

# 加密 (AES 32 位)
AES_KEY=this_is_a_32byte_key_for_aes_enc!!
