# CI 测试环境变量
# 与 .env.example 一致，但使用 CI service containers 的连接信息
NODE_ENV=test
PORT=3000

# MySQL (CI service container)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=snack_referral
DB_USER=root
DB_PASSWORD=root123

# Redis (CI service container)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=ci_test_secret_do_not_use_in_prod
JWT_EXPIRES_IN=1h

# 加密 (AES 32 位)
AES_KEY=this_is_a_32byte_key_for_aes_enc!!

# 以下为测试占位值，CI 中不真实调用支付接口
WX_APPID=wx_test_placeholder
WX_MCHID=1111111111
WX_PAY_V3_KEY=abcdefghijklmnopqrstuvwxyz123456
WX_NOTIFY_URL=https://test.example.com/callback

ALI_APPID=2021000000000000
ALI_PRIVATE_KEY_PATH=./keys/ali_app_private_key.pem
ALI_PUBLIC_KEY_PATH=./keys/ali_public_key.pem
ALI_NOTIFY_URL=https://test.example.com/callback

SMS_ACCESS_KEY=test_sms_key
SMS_ACCESS_SECRET=test_sms_secret
SMS_SIGN_NAME=测试店
SMS_TEMPLATE_CODE=SMS_TEST
